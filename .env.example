# Google Cloud / Vertex AI
# promptfoo's vertex: provider reads VERTEX_PROJECT_ID and VERTEX_REGION
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_REGION=us-central1
# GCLOUD_TOKEN is needed for Llama 4 MaaS providers; refresh with:
#   gcloud auth print-access-token  (expires hourly)
GCLOUD_TOKEN=

# Cerebras — https://cloud.cerebras.ai → API Keys
CEREBRAS_API_KEY=your-cerebras-api-key

# Cloudflare Workers AI
# Account ID: Cloudflare dashboard → right sidebar
# API Token: https://dash.cloudflare.com/profile/api-tokens (Workers AI template)
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# AWS Bedrock — credentials are read from ~/.aws/credentials
# Set AWS_PROFILE to select a named profile, or leave unset to use [default]
AWS_PROFILE=your-aws-profile
AWS_REGION=us-east-1
